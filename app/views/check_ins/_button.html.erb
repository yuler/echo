<%= turbo_frame_tag "check_in_button_#{post.id}" do %>
  <% check_in = Current.user&.check_ins&.find_by(post: post) %>
  <% if check_in %>
    <!-- Check-in completed state -->
    <div class="my-8 flex items-center justify-between p-4 bg-neutral-50 border border-neutral-100 rounded-2xl">
      <div class="flex items-center gap-3">
        <div class="w-8 h-8 bg-green-100 rounded-full flex items-center justify-center text-green-600">
          <%= inline_svg "check.svg", class: "w-4 h-4" %>
        </div>
        <div class="flex flex-col">
          <span class="text-body-sm text-neutral-900 font-medium">Checked in</span>
          <span class="text-caption text-neutral-500"><%= check_in.created_at.strftime("%I:%M %p, %b %d") %></span>
        </div>
      </div>
      <button type="button" data-action="click->share#open" class="btn bg-white border border-neutral-200 hover:bg-neutral-50 text-neutral-700 rounded-full px-4 py-2 transition-colors font-medium shadow-sm focus-ring text-sm inline-flex items-center gap-2">
        <%= inline_svg "share.svg", class: "w-4 h-4 opacity-70" %>
        Share
      </button>
    </div>
  <% elsif Current.user %>
    <!-- Tip check-in UI -->
    <div class="my-8 flex flex-col sm:flex-row items-center justify-between p-4 bg-neutral-50 border border-neutral-100 rounded-2xl gap-4">
      <div class="flex items-center gap-3 text-left">
        <div class="w-10 h-10 bg-white rounded-full flex items-center justify-center text-neutral-400 shadow-sm border border-neutral-100">
          <%= inline_svg "check-badge.svg", class: "w-5 h-5 text-neutral-400" %>
        </div>
        <div>
          <h3 class="text-body-sm font-medium text-neutral-900">Finished reading?</h3>
          <p class="text-caption text-neutral-500">Check in to track your learning streak</p>
        </div>
      </div>
      <%= button_to post_check_in_path(post), method: :post, class: "btn bg-neutral-900 hover:bg-neutral-800 text-white rounded-full px-6 py-2 w-full sm:w-auto font-medium shadow-sm transition-all text-sm inline-flex items-center justify-center", data: { turbo: true } do %>
        Check In
      <% end %>
    </div>
  <% else %>
    <div class="my-8 text-center pt-6 pb-2 border-t border-neutral-100">
      <p class="text-body-sm text-neutral-500 mb-3">Check in to track your reading streaks</p>
      <%= link_to "Sign in to check in", new_session_path, class: "btn bg-neutral-100 hover:bg-neutral-200 text-neutral-700 rounded-full px-6 py-2.5 transition-colors font-medium text-sm" %>
    </div>
  <% end %>
<% end %>
