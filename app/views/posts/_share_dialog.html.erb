<%# Share Dialog %>
<dialog data-share-target="dialog" class="backdrop:backdrop-blur-sm backdrop:bg-black/60 p-0 w-[calc(100%-2rem)] sm:w-full sm:max-w-md m-auto bg-transparent overflow-visible shadow-none" aria-modal="true">
  <div class="relative w-full mt-12 mb-12">
    <button type="button" data-action="click->share#close" class="absolute -top-12 right-0 sm:-right-8 z-10 text-white/70 hover:text-white focus-ring p-2 transition-colors">
      <%= inline_svg "x.svg", class: 'w-8 h-8' %>
    </button>

    <div class="bg-white rounded-2xl shadow-2xl p-5 overflow-hidden">
      <div class="mb-5 bg-neutral-100 rounded-xl overflow-hidden relative shadow-inner flex items-center justify-center">
      <img data-share-target="preview" class="w-full h-auto object-contain" />
      <div data-share-target="loading" class="absolute inset-0 flex items-center justify-center bg-neutral-100/80">
        <div class="w-8 h-8 border-4 border-neutral-300 border-t-neutral-800 rounded-full animate-spin"></div>
      </div>
    </div>

    <div class="grid grid-cols-2 gap-3">
      <button type="button" data-action="click->share#download" class="flex items-center justify-center gap-1 py-1.5 px-2.5 bg-neutral-900 text-white rounded-lg text-xs font-medium hover:bg-neutral-800 transition-colors focus-ring shadow-sm">
        <%= inline_svg "download.svg", class: 'w-3 h-3' %>
        Download
      </button>
      <button type="button" data-action="click->share#copyImage" class="flex items-center justify-center gap-1 py-1.5 px-2.5 bg-white border border-neutral-200 text-neutral-800 rounded-lg text-xs font-medium hover:bg-neutral-50 transition-colors focus-ring shadow-sm">
        <span data-share-target="copyDefault" class="inline-flex items-center gap-1">
          <%= inline_svg "copy.svg", class: 'w-3 h-3' %>
          Copy Image
        </span>
        <span data-share-target="copySuccess" class="hidden items-center gap-1">
          <%= inline_svg "circle-check.svg", class: 'w-3 h-3' %>
          Copied!
        </span>
      </button>
    </div>
    <%# Web share API fallback %>
    <div class="mt-3 hidden" data-share-target="webShareContainer">
      <button type="button" data-action="click->share#webShare" class="w-full flex items-center justify-center gap-2 py-2.5 px-4 bg-neutral-100 text-neutral-800 rounded-xl text-body-sm font-medium hover:bg-neutral-200 transition-colors focus-ring">
        Share via Device
      </button>
    </div>
    </div>
  </div>
</dialog>

<%# Share Poster Template (Hidden) %>
<div class="absolute overflow-hidden pointer-events-none z-[-1]" style="top: 0; left: 0; width: 0; height: 0;">
  <div data-share-target="posterTemplate" class="bg-white text-neutral-900 rounded-[32px] border-[6px] border-neutral-900 p-[48px] shadow-2xl flex flex-col box-border relative" style="width: 1080px; font-family: ui-sans-serif, system-ui, sans-serif;">
      <%# Header: Logo & Title %>
      <div class="flex flex-row items-center justify-between mb-[32px]">
        <%# Left: Logo & Title %>
        <div class="flex flex-row items-center gap-[20px]">
          <div class="flex flex-col items-center shrink-0">
            <img src="/icon.png" class="w-[88px] h-[88px] object-contain" />
          </div>
          <span class="text-[36px] font-bold tracking-[0.15em] text-neutral-900 leading-none pt-[8px]">ECHO</span>
        </div>

        <%# Right: QR Code %>
        <div class="flex flex-col items-center shrink-0">
          <img data-share-target="qrCodeImg" class="w-[140px] h-[140px] object-contain" />
        </div>
      </div>

      <%# Title %>
      <h1 class="text-[48px] font-bold leading-[1.3] text-neutral-900 whitespace-pre-wrap mb-[40px]"><%= post.title_en.presence || post.title %></h1>

      <div class="text-[32px] font-medium text-neutral-400 pb-[12px]">
        <%= post.created_at.strftime("%Y-%m-%d") %>
      </div>

      <%# Poster %>
      <% if post.poster_url.present? %>
        <div class="mt-[20px] mb-[40px] w-full rounded-[20px] overflow-hidden relative border-[4px] border-neutral-800 bg-neutral-100 flex-shrink-0 shadow-sm">
          <img src="<%= post.poster_url %>" class="w-full h-auto object-cover" crossorigin="anonymous" />
        </div>
      <% end %>

      <%# Guide %>
      <% if post.guide.present? %>
        <div class="border-l-[6px] border-neutral-300 pl-[32px] py-[8px]">
          <p class="text-[36px] text-neutral-500 leading-[1.6] whitespace-pre-wrap italic"><%= post.guide %></p>
        </div>
      <% end %>

      <div class="h-[60px] w-full flex-grow"></div>

      <%# Bottom Area: Recommender & Date %>
      <div class="flex flex-row items-end justify-between">
        <% if Current.user&.checked_in?(post) %>
          <div class="flex items-center gap-[24px]">
            <div class="w-[96px] h-[96px] rounded-full bg-neutral-900 border-[4px] border-white ring-[4px] ring-neutral-100 flex items-center justify-center text-white overflow-hidden shrink-0 shadow-sm">
              <% if Current.identity %>
                <span class="text-[42px] font-bold"><%= Current.identity.full_name.first.upcase %></span>
              <% else %>
                <span class="text-[42px] font-bold">U</span>
              <% end %>
            </div>
            <div class="flex flex-col justify-center">
              <span class="text-[40px] font-medium text-neutral-500">I've finished reading / listening to this post! ✨</span>
            </div>
          </div>
        <% else %>
          <div class="flex flex-col gap-[8px] mb-[12px]">
            <span class="text-[40px] font-bold text-neutral-900">ECHO</span>
            <span class="text-[28px] text-neutral-500">Discover more great content</span>
          </div>
        <% end %>
      </div>
    </div>
  </div>
